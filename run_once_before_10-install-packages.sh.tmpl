#!/usr/bin/env bash
#
# Installs system packages required by these dotfiles.
#
# This is a chezmoi `run_once_before_` script: it runs before chezmoi applies
# any files, and only re-runs when the contents of this file change. See
# https://www.chezmoi.io/user-guide/use-scripts-to-perform-actions/
#
# The `.tmpl` extension means chezmoi templates this file, so we can branch on
# `.chezmoi.os` to install the right set of packages for macOS or Ubuntu.

set -euo pipefail

log()  { printf '\033[1;34m[install-packages]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[install-packages]\033[0m %s\n' "$*" >&2; }

{{- if eq .chezmoi.os "darwin" }}

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------

if ! command -v brew >/dev/null 2>&1; then
    log "Installing Homebrew..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Make brew available in this shell (Apple Silicon vs. Intel)
if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

log "Updating Homebrew..."
brew update

# CLI tools used by the dotfiles. Keep this list in sync with what the zsh
# config and editors actually invoke.
BREW_FORMULAE=(
    chezmoi
    git
    zsh
    tmux
    neovim
    starship
    zoxide
    eza
    fzf
    ripgrep
    fd
    bat
    jq
    ack
    mise
    stylua
)

# GUI apps + macOS-only utilities used by ~/.config (sketchybar, aerospace,
# borders, wezterm).
BREW_CASKS=(
    wezterm
    nikitabobko/tap/aerospace
    felixkratz/formulae/sketchybar
    felixkratz/formulae/borders
    font-meslo-lg-nerd-font
)

log "Installing formulae: ${BREW_FORMULAE[*]}"
brew install "${BREW_FORMULAE[@]}"

log "Installing casks: ${BREW_CASKS[*]}"
for cask in "${BREW_CASKS[@]}"; do
    brew install --cask "$cask" || warn "Failed to install cask: $cask (continuing)"
done

{{- else if eq .chezmoi.os "linux" }}

# ---------------------------------------------------------------------------
# Linux (Ubuntu / Debian)
# ---------------------------------------------------------------------------

{{- if eq .chezmoi.osRelease.id "ubuntu" "debian" "pop" "linuxmint" }}

SUDO=""
if [[ "$EUID" -ne 0 ]]; then
    SUDO="sudo"
fi

log "Updating apt package lists..."
$SUDO apt-get update -y

APT_PACKAGES=(
    build-essential
    curl
    wget
    ca-certificates
    gnupg
    git
    zsh
    tmux
    unzip
    jq
    ack
    fzf
    ripgrep
    fd-find
    bat
)

log "Installing apt packages: ${APT_PACKAGES[*]}"
DEBIAN_FRONTEND=noninteractive $SUDO apt-get install -y "${APT_PACKAGES[@]}"

# Ubuntu ships these under non-standard binary names; symlink them so the
# rest of the config (and muscle memory) can use the canonical names.
mkdir -p "$HOME/.local/bin"
[[ -x /usr/bin/fdfind ]] && ln -sf /usr/bin/fdfind "$HOME/.local/bin/fd"
[[ -x /usr/bin/batcat ]] && ln -sf /usr/bin/batcat "$HOME/.local/bin/bat"

# Tools that aren't reliably packaged on Ubuntu LTS — install via their
# upstream installers so we get recent versions.

if ! command -v chezmoi >/dev/null 2>&1; then
    log "Installing chezmoi..."
    sh -c "$(curl -fsLS get.chezmoi.io)" -- -b "$HOME/.local/bin"
fi

if ! command -v mise >/dev/null 2>&1; then
    log "Installing mise..."
    curl -fsSL https://mise.run | sh
fi

if ! command -v starship >/dev/null 2>&1; then
    log "Installing starship..."
    curl -fsSL https://starship.rs/install.sh | sh -s -- --yes --bin-dir "$HOME/.local/bin"
fi

if ! command -v zoxide >/dev/null 2>&1; then
    log "Installing zoxide..."
    curl -fsSL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

if ! command -v eza >/dev/null 2>&1; then
    log "Installing eza..."
    $SUDO mkdir -p /etc/apt/keyrings
    curl -fsSL https://raw.githubusercontent.com/eza-community/eza/main/deb.asc \
        | $SUDO gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" \
        | $SUDO tee /etc/apt/sources.list.d/gierens.list >/dev/null
    $SUDO apt-get update -y
    $SUDO apt-get install -y eza
fi

if ! command -v nvim >/dev/null 2>&1; then
    log "Installing Neovim (latest stable AppImage)..."
    curl -fsSL -o /tmp/nvim.appimage \
        https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.appimage
    chmod +x /tmp/nvim.appimage
    mv /tmp/nvim.appimage "$HOME/.local/bin/nvim"
fi

{{- else }}
warn "Unsupported Linux distro: {{ .chezmoi.osRelease.id }}. Skipping package install."
{{- end }}

{{- else }}

warn "Unsupported OS: {{ .chezmoi.os }}. Skipping package install."

{{- end }}

log "Done."

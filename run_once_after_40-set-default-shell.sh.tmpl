#!/usr/bin/env bash
#
# Make zsh the login shell for the current user, if it isn't already.
#
# chezmoi only manages files inside $HOME, so on a freshly provisioned box
# the login shell stays whatever the system default was (usually bash on
# Linux). This script fixes that.
#
# This is a `run_once_after_` script: it runs after files are applied, and
# only re-runs when the contents of this file change. Bump the revision
# comment below to force a re-run.
#
# shell-revision: 1

set -euo pipefail

log()  { printf '\033[1;34m[set-default-shell]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[set-default-shell]\033[0m %s\n' "$*" >&2; }

ZSH_BIN="$(command -v zsh || true)"
if [[ -z "$ZSH_BIN" ]]; then
    warn "zsh not found on PATH; skipping. (The package install step should have installed it.)"
    exit 0
fi

# Resolve symlinks so we compare against the canonical path that getent /
# /etc/shells will report.
if command -v readlink >/dev/null 2>&1; then
    ZSH_BIN="$(readlink -f "$ZSH_BIN" 2>/dev/null || echo "$ZSH_BIN")"
fi

# What's the current login shell for this user?
CURRENT_SHELL=""
if command -v getent >/dev/null 2>&1; then
    CURRENT_SHELL="$(getent passwd "$USER" | awk -F: '{print $7}')"
else
    # macOS doesn't have getent; dscl works but $SHELL is good enough here
    # because login.zsh and Terminal.app honor the Directory Services value
    # which is what `dscl . -read /Users/$USER UserShell` returns.
    CURRENT_SHELL="$(dscl . -read "/Users/$USER" UserShell 2>/dev/null | awk '{print $2}')"
    CURRENT_SHELL="${CURRENT_SHELL:-$SHELL}"
fi

if [[ "$CURRENT_SHELL" == "$ZSH_BIN" ]]; then
    log "Login shell is already $ZSH_BIN; nothing to do."
    exit 0
fi

{{- if eq .chezmoi.os "linux" }}

SUDO=""
if [[ "$EUID" -ne 0 ]]; then
    SUDO="sudo"
fi

# Make sure zsh is a valid login shell. Debian/Ubuntu's zsh package adds
# itself to /etc/shells in its postinst, but belt-and-braces in case zsh
# was installed from source or PATH points somewhere unusual.
if ! grep -qxF "$ZSH_BIN" /etc/shells 2>/dev/null; then
    log "Adding $ZSH_BIN to /etc/shells..."
    echo "$ZSH_BIN" | $SUDO tee -a /etc/shells >/dev/null
fi

log "Changing login shell for $USER to $ZSH_BIN..."
# `sudo chsh` avoids the interactive password prompt that plain `chsh`
# triggers via PAM. If sudo itself needs a password we'll get prompted
# once, which is fine for an interactive `chezmoi init --apply` run.
if ! $SUDO chsh -s "$ZSH_BIN" "$USER"; then
    warn "Failed to change login shell automatically. Run:  chsh -s $ZSH_BIN"
fi

{{- else if eq .chezmoi.os "darwin" }}

# On macOS /bin/zsh has been the default since Catalina, but if the user
# is running an older account or installed zsh via Homebrew and wants that
# one, switch it over. /etc/shells already contains /bin/zsh; for the
# Homebrew zsh we need to add it.
if ! grep -qxF "$ZSH_BIN" /etc/shells 2>/dev/null; then
    log "Adding $ZSH_BIN to /etc/shells (requires sudo)..."
    echo "$ZSH_BIN" | sudo tee -a /etc/shells >/dev/null
fi

log "Changing login shell for $USER to $ZSH_BIN..."
if ! chsh -s "$ZSH_BIN"; then
    warn "Failed to change login shell automatically. Run:  chsh -s $ZSH_BIN"
fi

{{- else }}

warn "Unsupported OS: {{ .chezmoi.os }}. Set your login shell to zsh manually."

{{- end }}

log "Done. Log out and back in (or start a new login shell) for the change to take effect."
